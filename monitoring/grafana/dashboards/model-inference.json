{
  "dashboard": {
    "title": "Drug Designer - Model Inference Monitoring",
    "tags": ["drug-designer", "ml", "models", "inference", "production"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Model Inference Rate",
        "type": "graph",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 0},
        "description": "Inferences per second by model",
        "targets": [
          {
            "expr": "sum(rate(model_inference_total[5m])) by (model_name)",
            "legendFormat": "{{model_name}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Inferences/sec"},
          {"format": "short"}
        ],
        "legend": {
          "show": true,
          "alignAsTable": true,
          "avg": true,
          "current": true,
          "max": true
        }
      },
      {
        "id": 2,
        "title": "Model Inference Latency (p95)",
        "type": "graph",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 10},
        "description": "95th percentile inference latency by model",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(model_inference_duration_seconds_bucket[5m])) by (model_name, le))",
            "legendFormat": "{{model_name}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Latency (p95)", "logBase": 10},
          {"format": "short"}
        ],
        "legend": {
          "show": true,
          "alignAsTable": true,
          "avg": true,
          "current": true,
          "max": true
        }
      },
      {
        "id": 3,
        "title": "ESM-2 Protein Language Model",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
        "description": "ESM-2 inference performance (target: <10s for 100 proteins)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(model_inference_duration_seconds_bucket{model_name=\"esm2\"}[5m])) by (le))",
            "legendFormat": "p95 Latency",
            "refId": "A"
          },
          {
            "expr": "rate(model_inference_total{model_name=\"esm2\"}[5m])",
            "legendFormat": "Inference Rate",
            "refId": "B",
            "yAxisIndex": 1
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Latency"},
          {"format": "ops", "label": "Rate"}
        ],
        "legend": {
          "show": true,
          "alignAsTable": true,
          "avg": true,
          "current": true
        }
      },
      {
        "id": 4,
        "title": "MolFormer Molecule Transformer",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
        "description": "MolFormer inference performance (target: <5s for 100 molecules)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(model_inference_duration_seconds_bucket{model_name=\"molformer\"}[5m])) by (le))",
            "legendFormat": "p95 Latency",
            "refId": "A"
          },
          {
            "expr": "rate(model_inference_total{model_name=\"molformer\"}[5m])",
            "legendFormat": "Inference Rate",
            "refId": "B",
            "yAxisIndex": 1
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Latency"},
          {"format": "ops", "label": "Rate"}
        ],
        "legend": {
          "show": true,
          "alignAsTable": true,
          "avg": true,
          "current": true
        }
      },
      {
        "id": 5,
        "title": "Pathogenicity Prediction Model",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
        "description": "Pathogenicity prediction performance (target: <1min for 1000 variants)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(model_inference_duration_seconds_bucket{model_name=\"pathogenicity_prediction\"}[5m])) by (le))",
            "legendFormat": "p95 Latency",
            "refId": "A"
          },
          {
            "expr": "rate(model_inference_total{model_name=\"pathogenicity_prediction\"}[5m])",
            "legendFormat": "Inference Rate",
