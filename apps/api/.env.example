# Drug Designer API Environment Variables
DSS_MODE=studio
DSS_STORAGE_BACKEND=full

API_PORT=8000
API_LOG_LEVEL=info
API_CORS_ORIGINS=["http://localhost:5173", "https://drugdesigner.app"]

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=  # REQUIRED — set a secure Neo4j password

QDRANT_HOST=localhost
QDRANT_PORT=6333
REDIS_URL=redis://localhost:6379/0

POSTGRES_URL=postgresql+asyncpg://postgres:postgrespass@localhost:5432/drugdesigner

JWT_SECRET=  # REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_ALGORITHM=HS256

# Auth is enabled by default (§55.3). Set to "false" for local dev without login.
DRUGDESIGNER_AUTH_ENABLED=true
# Set to "false" when developing over HTTP (no TLS)
DSS_SECURE_COOKIES=true

# ── ESM Protein Language Models ───────────────────────────────────
# ESM-C 600M: weights auto-downloaded via ESM SDK on first use
ESMC_DEVICE=cuda

# ESM-3 Large via EvolutionaryScale Forge API (§24.2 — De Novo Protein Design)
# https://forge.evolutionaryscale.ai
ESM_FORGE_API_KEY=
