# Drug Designer — Production Environment Configuration
# Task 23.1: Docker Compose Production Stack
#
# Copy this file to .env.prod and fill in the values
# NEVER commit .env.prod to version control!

# ═══════════════════════════════════════════════════════════
# Database Configuration
# ═══════════════════════════════════════════════════════════

POSTGRES_USER=drugdesigner
POSTGRES_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
POSTGRES_DB=drugdesigner

# ═══════════════════════════════════════════════════════════
# Neo4j Graph Database
# ═══════════════════════════════════════════════════════════

NEO4J_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>

# ═══════════════════════════════════════════════════════════
# MinIO Object Storage
# ═══════════════════════════════════════════════════════════

MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>

# ═══════════════════════════════════════════════════════════
# Security & Authentication
# ═══════════════════════════════════════════════════════════

# Generate with: openssl rand -hex 32
JWT_SECRET=<CHANGE_ME_RANDOM_256_BIT_KEY>

# Generate with: openssl rand -hex 32
PG_ENCRYPT_KEY=<CHANGE_ME_RANDOM_256_BIT_KEY>

# ═══════════════════════════════════════════════════════════
# Grafana Configuration
# ═══════════════════════════════════════════════════════════

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>

# Generate with: openssl rand -hex 32
GRAFANA_SECRET_KEY=<CHANGE_ME_RANDOM_KEY>

# Optional: Custom domain for Grafana
GRAFANA_ROOT_URL=http://localhost:3001
GRAFANA_DOMAIN=localhost

# ═══════════════════════════════════════════════════════════
# Observability (Optional)
# ═══════════════════════════════════════════════════════════

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# ═══════════════════════════════════════════════════════════
# Application Settings
# ═══════════════════════════════════════════════════════════

ENVIRONMENT=production
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════
# External Services (Optional)
# ═══════════════════════════════════════════════════════════

# OpenAI API Key (if using hosted LLM)
OPENAI_API_KEY=

# Ollama endpoint (if using local LLM)
OLLAMA_BASE_URL=http://localhost:11434

# ═══════════════════════════════════════════════════════════
# Redis
# ═══════════════════════════════════════════════════════════

REDIS_URL=redis://redis:6379/0

# ═══════════════════════════════════════════════════════════
# Qdrant Vector Store
# ═══════════════════════════════════════════════════════════

QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ═══════════════════════════════════════════════════════════
# ESM Forge (Protein Structure Prediction)
# ═══════════════════════════════════════════════════════════

# EvolutionaryScale ESM-3 Forge API key
# Get from: https://forge.evolutionaryscale.ai
ESM_FORGE_API_KEY=

# ═══════════════════════════════════════════════════════════
# Data Source API Keys (Optional — enhances coverage)
# ═══════════════════════════════════════════════════════════

# NCBI E-utilities API key (increases rate limit from 3/s to 10/s)
# Get from: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# DisGeNET API key (required for full gene-disease associations)
# Get from: https://www.disgenet.org/api/#/Authorization
DISGENET_API_KEY=

# DrugBank API key (optional — enhances drug data)
DRUGBANK_API_KEY=

# BioGRID API key (optional — enhances PPI data)
BIOGRID_API_KEY=

# ═══════════════════════════════════════════════════════════
# MinIO / S3 Object Storage
# ═══════════════════════════════════════════════════════════

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=<CHANGE_ME_STRONG_PASSWORD>
S3_BUCKET=drugdesigner

# ═══════════════════════════════════════════════════════════
# Application Tuning
# ═══════════════════════════════════════════════════════════

# Cache TTL in seconds (default: 86400 = 24h)
CACHE_TTL=86400

# Max concurrent connector requests
MAX_CONCURRENT_REQUESTS=10

# Request timeout in seconds
REQUEST_TIMEOUT=30

# Data retention period (7d, 30d, 90d, 1y, forever)
DATA_RETENTION=30d

# ═══════════════════════════════════════════════════════════
# Notes
# ═══════════════════════════════════════════════════════════
#
# 1. Generate secure random keys:
#    openssl rand -hex 32
#
# 2. Use strong passwords (16+ characters, mixed case, numbers, symbols)
#
# 3. Never commit this file to version control
#
# 4. Backup this file securely
#
# 5. Rotate secrets regularly (every 90 days recommended)
