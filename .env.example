# ═══════════════════════════════════════════════════════════
# Drug Designer Platform — Environment Configuration
# ═══════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!
#
# Task 23.2: Environment Variables Configuration (NFR-MAIN-002)
#
# For production deployment, see docs/deployment/environment.md

# ═══════════════════════════════════════════════════════════
# Application Settings
# ═══════════════════════════════════════════════════════════

# Environment: development | staging | production
ENVIRONMENT=development

# Workbench mode: studio (Docker) | workbench (Tauri desktop)
DSS_MODE=studio

# Storage backend: full (Qdrant+Redis) | embedded (SQLite only)
DSS_STORAGE_BACKEND=full

# Log level: debug | info | warning | error | critical
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════
# API Server Configuration
# ═══════════════════════════════════════════════════════════

API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# CORS origins (JSON array format)
API_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ═══════════════════════════════════════════════════════════
# Database Configuration — PostgreSQL
# ═══════════════════════════════════════════════════════════

# PostgreSQL connection (primary database)
POSTGRES_USER=drugdesigner
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=drugdesigner
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full connection URL (alternative to individual params)
# Format: postgresql+asyncpg://user:password@host:port/database
POSTGRES_URL=

# Connection pool settings
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_TIMEOUT=30

# ═══════════════════════════════════════════════════════════
# Database Configuration — Neo4j (Knowledge Graph)
# ═══════════════════════════════════════════════════════════

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Neo4j connection pool
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60

# ═══════════════════════════════════════════════════════════
# Cache & Queue Configuration — Redis
# ═══════════════════════════════════════════════════════════

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Redis connection settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Redis pool settings
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# Cache TTL settings (seconds)
CACHE_DEFAULT_TTL=1800
CACHE_DISEASE_QUERY_TTL=3600
CACHE_TARGET_RANKING_TTL=3600
CACHE_EVIDENCE_TTL=7200

# ═══════════════════════════════════════════════════════════
# Vector Store Configuration — Qdrant
# ═══════════════════════════════════════════════════════════

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Qdrant API key (optional, for cloud deployment)
QDRANT_API_KEY=

# Qdrant collection settings
QDRANT_COLLECTION_NAME=drug_designer_vectors
QDRANT_VECTOR_SIZE=768

# ═══════════════════════════════════════════════════════════
# Object Storage Configuration — MinIO / S3
# ═══════════════════════════════════════════════════════════

# MinIO (S3-compatible) settings
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=drug-designer

# S3 settings (alternative to MinIO)
# When using MinIO locally, set S3_BUCKET + S3_ENDPOINT + S3_ACCESS_KEY + S3_SECRET_KEY
S3_BUCKET=drug-designer-artifacts
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE_ME_STRONG_PASSWORD
S3_REGION=us-east-1

# Local file storage (fallback)
LOCAL_STORE_PATH=./data/files

# SQLite path (embedded mode only)
SQLITE_DB_PATH=./data/drugsynth.db

# ═══════════════════════════════════════════════════════════
# Security & Authentication
# ═══════════════════════════════════════════════════════════

# JWT configuration
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=CHANGE_ME_RANDOM_256_BIT_KEY
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Authentication enabled (true | false)
DRUGDESIGNER_AUTH_ENABLED=true

# Secure cookies (set to false for HTTP development)
DSS_SECURE_COOKIES=true

# Encryption key for sensitive data (32-byte Fernet key)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_RANDOM_FERNET_KEY

# PostgreSQL encryption key (for pgcrypto)
# Generate with: openssl rand -hex 32
PG_ENCRYPT_KEY=CHANGE_ME_RANDOM_256_BIT_KEY

# Password hashing settings
PASSWORD_HASH_ALGORITHM=bcrypt
PASSWORD_HASH_ROUNDS=12

# ═══════════════════════════════════════════════════════════
# LLM Configuration
# ═══════════════════════════════════════════════════════════

# Ollama (local LLM)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=300

# OpenAI (hosted LLM)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=3

# LLM runtime mode: hosted | local | auto
LLM_RUNTIME_MODE=auto

# LLM security settings
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_ENABLE_PROMPT_INJECTION_DETECTION=true

# ═══════════════════════════════════════════════════════════
# Deep Learning Models Configuration
# ═══════════════════════════════════════════════════════════

# Model registry settings
MODEL_REGISTRY_PATH=./models
MODEL_CACHE_DIR=./cache/models

# ESM-C 600M Protein Language Model (replaces ESM-2 650M, §81.1)
# Weights downloaded automatically via 'pip install esm' SDK on first use
ESMC_DEVICE=cuda
# MODEL_CACHE_DIR already set above — ESM-C weights stored at MODEL_CACHE_DIR/esmc/

# ESM-3 Large De Novo Protein Design via EvolutionaryScale Forge API (§24.2)
# Get key at: https://forge.evolutionaryscale.ai
# Drug_Designer.md key: Name=Drug_Designer Value=[REDACTED]
ESM_FORGE_API_KEY=

# MolFormer Molecule Transformer
MOLFORMER_MODEL_PATH=
MOLFORMER_DEVICE=cuda

# Tissue Analysis Computer Vision Model
TISSUE_ANALYSIS_MODEL_PATH=
TISSUE_ANALYSIS_DEVICE=cuda

# Biomarker Quantification Neural Network
BIOMARKER_NN_MODEL_PATH=
BIOMARKER_NN_DEVICE=cuda

# Pathogenicity Prediction Deep Learning Model
PATHOGENICITY_MODEL_PATH=
PATHOGENICITY_MODEL_DEVICE=cuda

# Model inference settings
MODEL_BATCH_SIZE=32
MODEL_MAX_WORKERS=4

# ═══════════════════════════════════════════════════════════
# External API Keys — Biomedical Databases
# ═══════════════════════════════════════════════════════════

# NCBI (PubMed, dbSNP, ClinVar)
NCBI_API_KEY=
NCBI_EMAIL=

# DisGeNET (gene-disease associations)
DISGENET_API_KEY=

# OpenTargets (target validation)
OPENTARGETS_API_URL=https://api.platform.opentargets.org/api/v4/graphql
OPENTARGETS_API_KEY=

# ChEMBL (bioactive molecules)
CHEMBL_API_URL=https://www.ebi.ac.uk/chembl/api/data
CHEMBL_API_KEY=

# DrugBank (drug information)
DRUGBANK_API_KEY=

# gnomAD (population genetics)
GNOMAD_API_URL=https://gnomad.broadinstitute.org/api

# UniProt (protein sequences)
UNIPROT_API_URL=https://rest.uniprot.org

# Reactome (pathway database)
REACTOME_API_URL=https://reactome.org/ContentService

# KEGG (pathway database)
KEGG_API_URL=https://rest.kegg.jp

# String-DB (protein interactions)
STRING_DB_API_URL=https://string-db.org/api

# AlphaFold (protein structures)
ALPHAFOLD_API_URL=https://alphafold.ebi.ac.uk/api

# PubChem (chemical database)
PUBCHEM_API_URL=https://pubchem.ncbi.nlm.nih.gov/rest/pug

# Europe PMC (literature)
EUROPE_PMC_API_URL=https://www.ebi.ac.uk/europepmc/webservices/rest

# ClinicalTrials.gov
CLINICALTRIALS_API_URL=https://clinicaltrials.gov/api/v2

# ═══════════════════════════════════════════════════════════
# Monitoring & Observability (NFR-MAIN-002)
# ═══════════════════════════════════════════════════════════

# Prometheus metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana dashboards
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
GRAFANA_PORT=3001
GRAFANA_SECRET_KEY=CHANGE_ME_RANDOM_KEY
GRAFANA_ROOT_URL=http://localhost:3001
GRAFANA_DOMAIN=localhost

# Sentry error tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Loki log aggregation
LOKI_URL=http://localhost:3100
LOKI_ENABLED=false

# Application metrics
METRICS_ENABLED=true
METRICS_EXPORT_INTERVAL=60

# Health check settings
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# ═══════════════════════════════════════════════════════════
# Background Jobs & Workers
# ═══════════════════════════════════════════════════════════

# ARQ worker settings
ARQ_WORKER_COUNT=3
ARQ_MAX_JOBS=10
ARQ_JOB_TIMEOUT=3600

# Job queue settings
JOB_QUEUE_NAME=drug_designer_jobs
JOB_MAX_RETRIES=3
JOB_RETRY_DELAY=60

# ═══════════════════════════════════════════════════════════
# Rate Limiting & Circuit Breaker
# ═══════════════════════════════════════════════════════════

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Circuit breaker settings
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=300
CIRCUIT_BREAKER_EXPECTED_EXCEPTION_RATE=0.5

# Connector timeout settings (seconds)
CONNECTOR_TIMEOUT=30
CONNECTOR_MAX_RETRIES=3
CONNECTOR_RETRY_DELAY=5

# ═══════════════════════════════════════════════════════════
# WebSocket Configuration
# ═══════════════════════════════════════════════════════════

WEBSOCKET_ENABLED=true
WEBSOCKET_PING_INTERVAL=30
WEBSOCKET_PING_TIMEOUT=10
WEBSOCKET_MAX_CONNECTIONS=1000

# ═══════════════════════════════════════════════════════════
# Clinical Workflow Configuration
# ═══════════════════════════════════════════════════════════

# EHR data ingestion
EHR_SUPPORTED_FORMATS=HL7v2,HL7v3,FHIR_R4,CDA
EHR_PHI_REDACTION_ENABLED=true
EHR_BATCH_SIZE=100

# Phenotype clustering
PHENOTYPE_CLUSTERING_ALGORITHM=HDBSCAN
PHENOTYPE_MIN_CLUSTER_SIZE=5
PHENOTYPE_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Tissue analysis
TISSUE_ANALYSIS_WSI_FORMATS=SVS,TIFF,NDPI
TISSUE_ANALYSIS_BATCH_SIZE=1

# Biomarker quantification
BIOMARKER_FLOW_CYTOMETRY_FORMATS=FCS
BIOMARKER_REFERENCE_RANGES_ENABLED=true

# Genomic sequencing
GENOMIC_VCF_VERSION=4.2
GENOMIC_QUALITY_THRESHOLD=30
GENOMIC_DEPTH_THRESHOLD=10

# Pathogenicity prediction
PATHOGENICITY_CONFIDENCE_LEVEL=0.9
PATHOGENICITY_ACMG_COMPLIANCE=true

# Drug matching
DRUG_MATCHING_TOP_K=10
DRUG_MATCHING_MIN_SCORE=0.7

# Therapy stratification
THERAPY_STRATIFICATION_HLA_MATCHING=true
THERAPY_STRATIFICATION_RISK_THRESHOLD=0.8

# ═══════════════════════════════════════════════════════════
# MAV Consensus Configuration
# ═══════════════════════════════════════════════════════════

MAV_DEFAULT_JURY_SIZE=3
MAV_VOTING_RULE=majority
MAV_CONFIDENCE_THRESHOLD=0.8
MAV_TRUTHFUL_PAUSE_ENABLED=true

# ═══════════════════════════════════════════════════════════
# Export Configuration
# ═══════════════════════════════════════════════════════════

# Export formats
EXPORT_FORMATS=PDF,DOCX,SDF,CSV,JSON,GraphML,Cypher
EXPORT_MAX_SIZE_MB=100
EXPORT_TIMEOUT=300

# PDF export settings
PDF_TEMPLATE=scientific
PDF_INCLUDE_PROVENANCE=true

# Bulk export settings
BULK_EXPORT_ENABLED=true
BULK_EXPORT_MAX_PROJECTS=10

# ═══════════════════════════════════════════════════════════
# Performance & SLA Configuration
# ═══════════════════════════════════════════════════════════

# Performance targets (milliseconds)
SLA_DISEASE_QUERY_P95=15000
SLA_TARGET_RANKING_P95=15000
SLA_GRAPH_QUERY_P95=1000
SLA_PATHWAY_QUERY_P95=500
SLA_EVIDENCE_SEARCH_P95=5000

# Request timeout settings (seconds)
REQUEST_TIMEOUT=300
LONG_RUNNING_TIMEOUT=1800

# ═══════════════════════════════════════════════════════════
# Development & Testing
# ═══════════════════════════════════════════════════════════

# Debug mode (disable in production!)
DEBUG=false

# Testing settings
TESTING=false
TEST_DATABASE_URL=

# Mock external APIs (for testing)
MOCK_EXTERNAL_APIS=false

# ═══════════════════════════════════════════════════════════
# Deployment Configuration
# ═══════════════════════════════════════════════════════════

# Docker settings
DOCKER_REGISTRY=
DOCKER_IMAGE_TAG=latest

# Deployment mode
DEPLOYMENT_MODE=docker-compose

# Backup settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=

# ═══════════════════════════════════════════════════════════
# Notes
# ═══════════════════════════════════════════════════════════
#
# 1. Generate secure random keys:
#    - JWT_SECRET: python -c "import secrets; print(secrets.token_urlsafe(32))"
#    - ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#    - PG_ENCRYPT_KEY: openssl rand -hex 32
#
# 2. Use strong passwords (16+ characters, mixed case, numbers, symbols)
#
# 3. Never commit .env to version control (add to .gitignore)
#
# 4. Backup this file securely
#
# 5. Rotate secrets regularly (every 90 days recommended)
#
# 6. For production deployment, see docs/deployment/environment.md
#
# 7. All CHANGE_ME values MUST be replaced before deployment

# ═══════════════════════════════════════════════════════════
# Connector API Keys (Optional — enhances coverage)
# ═══════════════════════════════════════════════════════════
# Each connector degrades gracefully if its key is absent.
# Register for free keys at the URLs below.

# BioGRID — protein/genetic interaction database
# Register: https://webservice.thebiogrid.org/ → "Access Key"
BIOGRID_API_KEY=

# OMIM — Online Mendelian Inheritance in Man
# Register: https://www.omim.org/api → requires institutional/research affiliation
OMIM_API_KEY=

# Semantic Scholar — higher rate limits (100 req/s vs 1 req/s without key)
# Register: https://www.semanticscholar.org/product/api#api-key-form (free)
S2_API_KEY=

# Nature / Springer Open Access
# Register: https://dev.springernature.com/ → "Create Application"
NATURE_API_KEY=

# UMLS — Unified Medical Language System
# Register: https://uts.nlm.nih.gov/uts/signup-login (free NLM account)
UMLS_API_KEY=

# Wiley TDM — text/data mining access
# Register: https://onlinelibrary.wiley.com/library-info/resources/text-and-datamining
WILEY_API_KEY=

# NCBI E-utilities (already listed above; also used by MedGen, ClinVar, dbSNP)
# Register: https://www.ncbi.nlm.nih.gov/account/ (free)
# NCBI_API_KEY already defined above

# DisGeNET — disease–gene associations (already listed above)
# Register: https://www.disgenet.com/plans
# DISGENET_API_KEY already defined above

# GTR / NLM Genetic Testing Registry (optional key for higher quotas)
GTR_API_KEY=

# COSMIC — Catalogue Of Somatic Mutations In Cancer
# Register: https://cancer.sanger.ac.uk/cosmic/register
COSMIC_API_KEY=

# ClinicalTrials.gov (currently public; reserve for future auth requirements)
CLINICALTRIALS_API_KEY=

# Europe PMC Annotations API (currently open; key for bulk access)
EUROPE_PMC_API_KEY=

# PharmGKB (currently open; key for extended access)
PHARMGKB_API_KEY=

# DrugCentral (currently open PostgreSQL dump; reserve for hosted API)
DRUGCENTRAL_API_KEY=
